{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "mcp__plugin_everything-claude-code_exa__web_search_exa",
      "mcp__plugin_everything-claude-code_github__search_repositories",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status --short 2>/dev/null | grep -q '\\.py$' && echo 'Python files modified — run /verify before committing.' || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
